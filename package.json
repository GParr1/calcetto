{
  "name": "calcetto",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.js",
  "homepage": "https://GParr1.github.io/app1",
  "scripts": {
    "clean:node_modules": "npx rimraf node_modules package-lock.json && npm install",
    "start:expo": "expo start",
    "build:web": "expo export --platform web",
    "start:web": "cross-env REACT_APP_PLATFORM=web expo start --web",
    "start:android": "cross-env REACT_APP_PLATFORM=android expo start --android",
    "start:ios": "cross-env REACT_APP_PLATFORM=ios expo start --ios",
    "android": "cross-env REACT_APP_PLATFORM=android expo run:android",
    "ios": "cross-env REACT_APP_PLATFORM=ios expo run:ios",
    "build:expo-web":"expo export:web",
    "lint": "eslint src --fix",
    "format": "prettier --config .prettierrc.json --write \"{src,test}/**/*.{js,ts,tsx}\"",
    "fix": "npm run format && npm run lint",
    "predeploy:expo-web": "npm run build:expo-web",
    "deploy:expo-web": "gh-pages -d dist"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@react-native-async-storage/async-storage": "1.24.0",
    "@react-native-community/datetimepicker": "8.4.1",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/native": "^7.1.19",
    "@react-navigation/stack": "^7.6.3",
    "@reduxjs/toolkit": "^2.10.0",
    "axios": "^1.9.0",
    "bootstrap": "^5.3.6",
    "browser-image-compression": "^2.0.2",
    "expo": "~53.0.27",
    "expo-camera": "~16.1.11",
    "expo-image-picker": "~16.1.4",
    "firebase": "^11.5.0",
    "prop-types": "^15.8.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-web": "^0.20.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.30.1",
    "react-select": "^5.10.2",
    "redux-persist": "^6.0.0",
    "swiper": "^12.0.3",
    "uuid": "^11.1.0",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@types/react": "~19.2.0",
    "@types/react-dom": "^19.2.3",
    "@types/react-native": "^0.72.8",
    "@types/react-router-dom": "^5.3.3",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-plugin-react-native-web": "^0.17.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "gh-pages": "^6.3.0",
    "prettier": "^3.5.3",
    "typescript": "~5.8.3"
  }
}