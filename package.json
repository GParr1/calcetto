{
  "name": "calcetto",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.js",
  "homepage": "https://GParr1.github.io/app1",
  "scripts": {
    "clean:node_modules": "npx rimraf node_modules package-lock.json && npm install",
    "start_web:expo": "cross-env REACT_APP_PLATFORM=web expo start --web",
    "start_android:expo": "cross-env REACT_APP_PLATFORM=android expo run:android",
    "start_ios:expo": "cross-env REACT_APP_PLATFORM=ios eas build -p ios --profile development",
    "start:expo": "expo start",
    "start:web": "cross-env REACT_APP_PLATFORM=web react-scripts start",
    "build:web": "cross-env REACT_APP_PLATFORM=web react-scripts build",
    "test:web": "react-scripts test --watchAll=false",
    "coverage:web": "react-scripts test --watchAll=false --coverage",
    "start:app": "cross-env REACT_APP_PLATFORM=android expo start",
    "android": "cross-env REACT_APP_PLATFORM=android expo run:android",
    "ios": "cross-env REACT_APP_PLATFORM=ios expo run:ios",
    "web:expo": "cross-env REACT_APP_PLATFORM=web expo start --web",
    "start": "cross-env REACT_APP_PLATFORM=web react-scripts start",
    "build": "cross-env REACT_APP_PLATFORM=web react-scripts build",
    "lint": "eslint src --fix",
    "format": "prettier --config .prettierrc.json --write \"{src,test}/**/*.{js,ts,tsx}\"",
    "fix": "npm run format && npm run lint",
    "predeploy": "npm run build:web",
    "deploy": "gh-pages -d build",
    "deploy:manual": "npm run predeploy && gh-pages -d build"
  },
  "dependencies": {
    "@expo/metro-runtime": "^5.0.5 ",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/datetimepicker": "^8.6.0",
    "@react-native-picker/picker": "^2.11.1",
    "@react-navigation/native": "^7.1.19",
    "@react-navigation/stack": "^7.6.3",
    "@reduxjs/toolkit": "^2.10.0",
    "@tensorflow-models/body-pix": "^2.2.1",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "@tensorflow/tfjs-react-native": "^1.0.0",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.9.0",
    "bootstrap": "^5.3.6",
    "browser-image-compression": "^2.0.2",
    "expo": "^53.0.23",
    "expo-camera": "^55.0.9",
    "expo-image-picker": "^55.0.11",
    "firebase": "^11.5.0",
    "firebase-admin": "^13.5.0",
    "prop-types": "^15.8.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "^5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-web": "^0.20.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.30.1",
    "react-scripts": "^0.0.0",
    "react-select": "^5.10.2",
    "redux-persist": "^6.0.0",
    "swiper": "^12.0.3",
    "uuid": "^11.1.0",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@types/react": "~19.0.10",
    "@types/react-native": "^0.72.8",
    "@types/react-router-dom": "^5.3.3",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-plugin-react-native-web": "^0.17.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "gh-pages": "^6.3.0",
    "prettier": "^3.5.3",
    "typescript": "~5.8.3"
  },
  "jest": {
    "moduleNameMapper": {
      "^swiper/react$": "<rootDir>/src/__mocks__/swiperReactMock.js",
      "^swiper/css$": "<rootDir>/src/__mocks__/styleMock.js"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!swiper/)"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "env": {
      "jest": true
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
